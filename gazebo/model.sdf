          </pbr>
        </material>
      </visual>

    </link>

    <!-- IMU Link (unchanged) -->
    <link name='imu_link'>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.00001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00002</iyy>
          <iyz>0</iyz>
          <izz>0.00002</izz>
        </inertia>
      </inertial>
      <sensor name="imu_sensor" type="imu">
        <gz_frame_id>imu_link</gz_frame_id>
        <pose degrees="true">0 0 0 180 0 0</pose>
        <always_on>1</always_on>
        <update_rate>1000.0</update_rate>
      </sensor>
    </link>
    <joint name='imu_joint' type='revolute'>
      <child>imu_link</child>
      <parent>base_link</parent>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>0</lower>
          <upper>0</upper>
          <effort>0</effort>
          <velocity>0</velocity>
        </limit>
        <dynamics>
          <damping>1.0</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- ==========================================
         LIDAR LINK: Benewake TF03-180 single-beam downward LiDAR.

         Specs matched to TF03-180 datasheet v1.2.1:
           - Range       : 0.1m ~ 180.0m  (90% reflectivity, no glare)
           - Resolution  : 1cm  -> range resolution = 0.01
           - Update rate : 100 Hz (default; adjustable 1-1000 Hz)
           - FOV         : 0.5 degrees  (single beam)
           - Noise       : Gaussian stddev = 0.03 m  (1-sigma repeatability < 3cm per datasheet)
           - Mass/size   : 89g, 44x43x32 mm body represented as visual box

         Pose of lidar_link relative to base_link:
           - Translated 0.05 m downward (below the frame, clear of prop wash)
           - NO rotation on the link itself (0 0 0 0 0 0)

         Sensor pose inside the link:
           - Rotated PI radians on X-axis (180 deg) so that Gazebo's
             default +Z beam direction flips to -Z (pointing DOWN).
             This is the standard and reliable way to achieve downward
             pointing in Gazebo Harmonic / Fortress.
         ========================================== -->
    <link name="lidar_link">
      <!-- Link pose: 5 cm below base_link centre, no rotation -->
      <pose>0 0 -0.05 0 0 0</pose>

      <inertial>
        <!-- TF03-180 mass: 89g -->
        <mass>0.089</mass>
        <inertia>
          <!-- Box 44x43x32 mm inertia (thin slab approximation) -->
          <ixx>0.000034</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.000035</iyy>
          <iyz>0</iyz>
          <izz>0.000033</izz>
        </inertia>
      </inertial>

      <!-- Physical body: 44x43x32 mm aluminium box (TF03-180 dimensions) -->
      <visual name="lidar_body_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.044 0.043 0.032</size>
          </box>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
          <specular>0.5 0.5 0.5 1</specular>
        </material>
      </visual>
      <collision name="lidar_body_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.044 0.043 0.032</size>
          </box>
        </geometry>
      </collision>

      <sensor name="tf03_180_lidar" type="gpu_lidar">
        <topic>/lidar_down</topic>

        <!--
          Gazebo gpu_lidar default beam direction is +X.
          Rotate -90 deg about Y to tilt +X down to -Z (downward).
          This is the correct rotation for a downward-facing single-beam LiDAR.
          Using degrees="true" for clarity.
        -->
        <pose degrees="true">0 0 0 0 90 0</pose>

        <!-- TF03-180 default update rate: 100 Hz -->
        <update_rate>100</update_rate>

        <lidar>
          <scan>
            <!-- Single-beam sensor: 1 sample, FOV = 0.5 deg = 0.00873 rad -->
            <horizontal>
              <samples>1</samples>
              <resolution>1</resolution>
              <min_angle>-0.004363</min_angle>   <!-- -0.25 deg -->
              <max_angle>0.004363</max_angle>    <!--  +0.25 deg -->
            </horizontal>
            <vertical>
              <samples>1</samples>
              <resolution>1</resolution>
              <min_angle>-0.004363</min_angle>   <!-- -0.25 deg -->
              <max_angle>0.004363</max_angle>    <!--  +0.25 deg -->
            </vertical>
          </scan>

          <range>
            <!-- TF03-180: min 0.1m, max 180m (90% reflectivity), resolution 1cm -->
            <min>0.1</min>
            <max>180.0</max>
            <resolution>0.01</resolution>
          </range>

          <noise>
            <!--
              Gaussian noise to simulate TF03-180 repeatability:
                1-sigma repeatability < 3 cm  -> stddev = 0.03 m
              Mean = 0 (no systematic bias in simulation)
            -->
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.03</stddev>
          </noise>
        </lidar>

        <always_on>1</always_on>
        <visualize>true</visualize>
      </sensor>
    </link>

    <!-- Fixed joint: rigidly attaches lidar_link to base_link -->
    <joint name='lidar_joint' type='fixed'>
      <child>lidar_link</child>
      <parent>base_link</parent>
    </joint>

    <!-- Rotors (all unchanged) -->
    <link name='rotor_0'>
      <pose>0.13 -0.22 0.023 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.025</mass>
        <inertia>
          <ixx>9.75e-06</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.000166704</iyy>
          <iyz>0</iyz>
          <izz>0.000167604</izz>
        </inertia>
      </inertial>
      <collision name='rotor_0_collision'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.005</length>
            <radius>0.1</radius>
          </cylinder>
        </geometry>
        <surface>
          <contact>
            <ode/>
